# Software Foundation; either version 2 of the License, or (at your option)
# any later version.
#
# Usage:
#   misc/modconfig [OPTIONS] COMMAND
#
# Commands:
#   configure    Interactively select modules, then write build/modconfig.ini
#                and print the meson configure command.
#   show         Print current module enable/disable status for a build dir.
#   help         Show this help.
#
# Options:
#   --builddir=DIR   Meson build directory (default: build)
#   --srcdir=DIR     Source directory (default: directory of this script/..)
#   --quiet|-q       Only show errors.
#
# After running configure, apply the settings to an existing build directory:
#   meson configure --native-file build/modconfig.ini build
#
# Or supply the native file when setting up a new build:
#   meson setup --native-file modconfig.ini builddir

mc_pn=$(basename "$0")
mc_builddir=build
mc_srcdir=$(cd "$(dirname "$0")/.." && pwd)
mc_flag_quiet=no

# ---------------------------------------------------------------------------
# Parse options
# ---------------------------------------------------------------------------
while true; do
  case "${1}" in
    --builddir=*)  mc_builddir="${1#--builddir=}" ;;
    --builddir)    shift; mc_builddir="${1}" ;;
    --srcdir=*)    mc_srcdir="${1#--srcdir=}" ;;
    --srcdir)      shift; mc_srcdir="${1}" ;;
    --quiet|-q)    mc_flag_quiet=yes ;;
    --*)           echo "${mc_pn}: warning: unknown option '${1}'." >&2 ;;
    *)             break ;;
  esac
  shift || break
done

mc_cmd="${1:-help}"
shift 2>/dev/null || true

# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------
mc_msg() {
  if [ "${mc_flag_quiet}" != yes ]; then
    echo "$*"
  fi
}
mc_err() { echo "${mc_pn}: error: $*" >&2; }

# ---------------------------------------------------------------------------
# Module definitions: name description
# Modules with external deps (compress, python) are always listed; modconfig
# will note that they also require libraries to be available at build time.
# ---------------------------------------------------------------------------
mc_all_modules="
assoc        'Channel-name/topic association'
blowfish     'Blowfish encryption (legacy password support)'
channels     'IRC channel management (required for channel ops)'
compress     'Botnet traffic compression (requires zlib at build time)'
console      'DCC console support'
ctcp         'CTCP reply handling'
dns          'Async DNS resolver'
filesys      'DCC file system'
ident        'RFC 1413 ident (username) lookups'
irc          'IRC protocol support (required for IRC connectivity)'
notes        'Inter-user note messaging'
pbkdf2       'PBKDF2 password hashing (recommended encryption module)'
python       'Python scripting support (requires Python 3.8+ at build time)'
seen         'Last-seen user tracking'
server       'IRC server connections (required for IRC connectivity)'
share        'Botnet userfile sharing'
transfer     'DCC file transfer'
twitch       'Twitch IRC support'
uptime       'Bot uptime reporting'
webui        'WebSocket-based web UI'
woobie       'Example/template module'
"

# ---------------------------------------------------------------------------
# Read current state from an existing native file
# ---------------------------------------------------------------------------
mc_inifile="${mc_builddir}/modconfig.ini"

mc_is_enabled() {
  # $1 = module name; returns 0 if enabled, 1 if disabled
  modname="$1"
  if [ -f "${mc_inifile}" ]; then
    val=$(grep "^module-${modname}" "${mc_inifile}" 2>/dev/null | \
          sed "s/.*=\s*//;s/'//g;s/\"//g" | tr -d ' ')
    if [ "${val}" = "false" ]; then
      return 1
    fi
  fi
  return 0  # enabled by default
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
case "x${mc_cmd}" in

xhelp)
  cat <<EOF
Usage: ${mc_pn} [OPTIONS] COMMAND

Commands:
  configure    Interactively select modules and write modconfig.ini.
  show         Show current module enable/disable status.
  help         Display this help.

Options:
  --builddir=DIR   Meson build directory to write/read modconfig.ini
                   (default: build)
  --srcdir=DIR     Project source root (default: auto-detected)
  --quiet|-q       Suppress informational output.

Workflow:
  1.  misc/modconfig configure
  2.  meson setup --native-file build/modconfig.ini builddir
      — OR, to reconfigure an existing build —
      meson configure --native-file build/modconfig.ini builddir

Individual options can also be set directly with meson:
  meson configure -Dmodule-dns=false builddir

EOF
  ;;

xshow)
  mc_msg ""
  mc_msg "Module status (from ${mc_inifile}):"
  mc_msg ""
  printf "%-16s %s\n" "MODULE" "STATUS"
  printf "%-16s %s\n" "------" "------"
  echo "${mc_all_modules}" | grep -v '^$' | while read -r modname desc; do
    if mc_is_enabled "${modname}"; then
      printf "%-16s %s\n" "${modname}" "enabled"
    else
      printf "%-16s %s\n" "${modname}" "disabled"
    fi
  done
  mc_msg ""
  ;;

xconfigure)
  mc_msg ""
  mc_msg "            -*-    Eggdrop Interactive Module Selection    -*-"
  mc_msg ""
  mc_msg "Modules are built as shared libraries loaded at runtime."
  mc_msg "Press Enter to keep the current state, or type e/d to enable/disable."
  mc_msg ""

  # Build up the ini content
  mc_ini_content="[project options]"

  echo "${mc_all_modules}" | grep -v '^$' | while read -r modname desc; do
    desc=$(echo "${desc}" | tr -d "'")

    if mc_is_enabled "${modname}"; then
      mc_state=enabled
      mc_prompt="(E)nable / (d)isable [E/d]"
    else
      mc_state=disabled
      mc_prompt="(e)nable / (D)isable [e/D]"
    fi

    mc_msg ""
    mc_msg "  ${desc}"
    mc_msg ""

    while true; do
      printf "  '%s' is %s: %s -> " "${modname}" "${mc_state}" "${mc_prompt}"
      read -r mc_response

      # Normalise
      mc_response=$(echo "${mc_response}" | tr '[:upper:]' '[:lower:]')

      if [ -z "${mc_response}" ]; then
        break  # keep current state
      elif [ "${mc_response}" = "e" ]; then
        mc_state=enabled
        mc_msg "  Enabled '${modname}'."
        break
      elif [ "${mc_response}" = "d" ]; then
        mc_state=disabled
        mc_msg "  Disabled '${modname}'."
        break
      else
        mc_msg "  Please enter 'e' to enable, 'd' to disable, or Enter to keep."
      fi
    done

    if [ "${mc_state}" = enabled ]; then
      mc_ini_content="${mc_ini_content}
module-${modname} = true"
    else
      mc_ini_content="${mc_ini_content}
module-${modname} = false"
    fi
  done

  # Write the native file
  mkdir -p "${mc_builddir}"
  printf '%s\n' "${mc_ini_content}" > "${mc_inifile}"

  mc_msg ""
  mc_msg "Written: ${mc_inifile}"
  mc_msg ""
  mc_msg "To apply to a new build directory:"
  mc_msg "  meson setup --native-file ${mc_inifile} builddir"
  mc_msg ""
  mc_msg "To reconfigure an existing build:"
  mc_msg "  meson configure --native-file ${mc_inifile} builddir"
  mc_msg ""
  ;;

*)
  mc_err "unknown command '${mc_cmd}'"
  echo "Run '${mc_pn} help' for usage."
  exit 1
  ;;

esac

exit 0
